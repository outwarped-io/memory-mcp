# memory-mcp configuration. See README.md for details.
#
# v1 LOCAL-ONLY WARNING: there is no auth in v1. Keep MCP_HTTP_HOST on
# 127.0.0.1 unless you understand the security contract.

# Postgres
POSTGRES_USER=memory
POSTGRES_PASSWORD=memory
POSTGRES_DB=memory
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+asyncpg://memory:memory@postgres:5432/memory

# Qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# Neo4j
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_AUTH=neo4j/memorymemory
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memorymemory

# memory-mcp service
#
# Inside the docker-compose stack:
#   - the container always listens on 0.0.0.0:8080 (hardcoded internally so
#     Docker can route traffic from sibling containers).
#   - the host-side published port is bound to 127.0.0.1 only via
#     ``ports: ${MCP_HTTP_BIND:-127.0.0.1}:${MEMORY_MCP_HOST_PORT:-8080}:8080``.
#     The 127.0.0.1 bind is the enforcement point for the v1 LOCAL-ONLY
#     contract.
#
# MEMORY_MCP_HOST_PORT — host-side port. Default is 8080. Override to any
# free port (e.g. 8090) when running two memory-mcp stacks side by side on
# the same host.
#
# For a NON-DOCKER direct ``uvicorn`` run, set MCP_HTTP_HOST=127.0.0.1.
MEMORY_MCP_HOST_PORT=8080
# http | stdio
MCP_TRANSPORT=http
LOG_LEVEL=INFO

# Image tag produced by ``docker compose build`` and consumed by the
# ``image:`` lines. Default ``dev`` keeps every rebuild on a non-release
# tag so the production tag (e.g. ``v0.2.0``) is never silently overwritten
# by a dev iteration. To cut a release image:
#   MEMORY_MCP_IMAGE_TAG=v0.2.0 docker compose build
# (or retag a finished ``:dev`` build with ``docker tag``).
MEMORY_MCP_IMAGE_TAG=dev

# Embedder
EMBEDDER=local
EMBEDDING_MODEL_ID=all-MiniLM-L6-v2

# Backends
VECTOR_BACKEND=qdrant
GRAPH_BACKEND=neo4j

# ---------------------------------------------------------------------------
# LLM subsystem (Phase 2.2) — used by DreamSummarizer and F5 mem_digest when DREAM_SUMMARIZER=llm.
# ---------------------------------------------------------------------------
# Backend: ``null`` (default; raises LLMUnavailableError → DreamSummarizer
# falls back to template-style content per call), ``ollama`` (requires the
# sibling ``ollama`` service from docker-compose --profile llm), or
# ``openai_compatible`` (any OpenAI-shaped endpoint, e.g. vLLM, llama.cpp,
# OpenAI itself, OpenRouter — requires LLM_BASE_URL + LLM_API_KEY).
LLM_BACKEND=null
# Empty → use backend default (ollama: http://ollama:11434). REQUIRED for
# openai_compatible.
LLM_BASE_URL=
LLM_MODEL_ID=llama3.2:3b
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60

# Summarizer used by dream passes. ``llm`` (default) → LLMSummarizer; falls
# back to template content on per-call LLM failure with llm_failed=true.
# ``template`` → TemplateSummarizer (pure-Python, no LLM). Both are
# first-class shipped features.
DREAM_SUMMARIZER=llm

# Local-default agent (used when client omits X-Agent-Id)
LOCAL_DEFAULT_AGENT_FILE=/var/lib/memory-mcp/default-agent.json
LOCAL_DEFAULT_AGENT_NAME=default-local-agent

# OpenTelemetry (reserved for v1.5; setting this currently emits a
# one-time WARN and is otherwise ignored)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
